{
    "author": "Friedemann Sommer <social@friedemannsommer.com>",
    "bugs": {
        "url": "https://github.com/friedemannsommer/astro-node-fastify/issues"
    },
    "dependencies": {
        "@fastify/compress": "^9.0.0",
        "@fastify/static": "^9.1.3",
        "fastify": "^5.8.5"
    },
    "description": "Astro Fastify integration for Node.js",
    "devDependencies": {
        "@arethetypeswrong/core": "0.18.4",
        "@biomejs/biome": "2.5.1",
        "@types/chai": "5.2.3",
        "@types/node": "24.13.2",
        "astro": "7.0.3",
        "chai": "6.2.2",
        "get-port": "7.2.0",
        "pino": "10.3.1",
        "publint": "0.3.21",
        "tsdown": "0.22.3",
        "tsx": "4.22.4",
        "typedoc": "0.28.19",
        "typedoc-github-theme": "0.4.0",
        "typedoc-plugin-mdn-links": "5.1.1",
        "typedoc-plugin-missing-exports": "4.1.3",
        "typescript": "6.0.3",
        "unplugin-unused": "0.5.7"
    },
    "engines": {
        "node": ">=22.12.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.mjs"
        },
        "./preview": {
            "types": "./dist/preview.d.ts",
            "default": "./dist/preview.mjs"
        },
        "./entrypoint": {
            "types": "./dist/entrypoint.d.ts",
            "default": "./dist/entrypoint.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "homepage": "https://friedemannsommer.github.io/astro-node-fastify/",
    "keywords": [
        "astro",
        "fastify",
        "compression",
        "astro-adapter"
    ],
    "license": "MIT",
    "main": "./dist/index.mjs",
    "name": "astro-node-fastify",
    "peerDependencies": {
        "astro": "~7.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/friedemannsommer/astro-node-fastify.git",
        "directory": "astro-adapter"
    },
    "scripts": {
        "build": "tsdown",
        "check": "pnpm run check:biome && pnpm run check:ts",
        "check:biome": "biome check src",
        "check:ci": "biome ci src && pnpm run check:ts",
        "check:ts": "tsc -p tsconfig.json --noEmit",
        "docs": "typedoc",
        "test": "node --import=tsx --test --test-timeout=1200000 \"src/tests/**/*.spec.ts\""
    },
    "sideEffects": false,
    "type": "module",
    "version": "0.8.2"
}
