{
    "name": "main",
    "version": "0.0.0",
    "private": true,
    "packageManager": "pnpm@11.6.0",
    "scripts": {
        "build": "pnpm --filter astro-node-fastify build",
        "build:clean": "pnpm --filter astro-node-fastify build:clean",
        "check": "pnpm --filter astro-node-fastify check",
        "check:ci": "pnpm --filter astro-node-fastify check:ci",
        "docs": "pnpm --filter astro-node-fastify docs",
        "release": "pnpm --filter astro-node-fastify build && changeset publish",
        "test": "pnpm --filter astro-node-fastify test"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0"
    }
}
